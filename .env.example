# Fortis — environment variable template
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. NEVER commit real keys.

# ----- Public client URL -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Supabase (Phase 2) -----
# From Supabase Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY — never expose to browser

# ----- Anthropic (Phase 2, server-only) -----
# Set per-environment in Vercel; do NOT prefix with NEXT_PUBLIC_
ANTHROPIC_API_KEY=

# ----- Optional: market data (Phase 2) -----
# Currently called from the browser in the prototype — will move server-side in Phase 2
FINNHUB_API_KEY=

# ----- Optional: error monitoring -----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
